    "wrangler": "^3.114.0"
  },
  "dependencies": {
    "@lark-base-open/js-sdk": "^0.5.0",
    "bootstrap": "^5.3.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jquery": "^3.7.1",
    "qrcode": "^1.5.4",
    "reset-css": "^5.0.1",
    "uuid": "^11.1.0"
  }
